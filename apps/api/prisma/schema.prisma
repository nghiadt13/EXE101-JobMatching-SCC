generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  RECRUITER
  CANDIDATE
}

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

enum ApplicationStatus {
  PENDING_MATCHING
  APPLIED
  REVIEWING
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  name      String
  role      UserRole  @default(CANDIDATE)
  avatar    String?
  planName  String    @default("Free Plan")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  candidate Candidate?
  jobs      Job[]
  savedJobs SavedJob[]
  notifications Notification[]

  @@index([email])
  @@index([role])
  @@index([deletedAt])
}

model Candidate {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone     String?
  location  Json?
  bio       String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cvs          CV[]
  applications Application[]
  recommendationScans RecommendationScan[]

  @@index([userId])
}

model CV {
  id          String    @id @default(uuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  fileName    String
  filePath    String
  fileSize    Int
  mimeType    String
  parsedData  Json
  skills      Json
  skillAtoms  Json?
  rawText     String?   @db.Text
  candidateProfile Json?
  candidateProfileVersion String?
  isPrimary   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  applications Application[]

  @@index([candidateId])
  @@index([isPrimary])
  @@index([deletedAt])
}

model Job {
  id             String    @id @default(uuid())
  recruiterId    String
  recruiter      User      @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  companyId      String?
  company        Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  categoryId     String?
  category       JobCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  title          String
  slug           String    @unique
  description    String    @db.Text
  shortDescription String?
  skills         Json
  skillAtoms     Json?
  requirementsSchema Json?
  requirementsSchemaVersion String?
  location       Json?
  salaryMin      Int?
  salaryMax      Int?
  employmentType String
  status         JobStatus @default(DRAFT)
  publishedAt    DateTime?
  closedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  applications Application[]
  savedByUsers SavedJob[]
  recommendationResults RecommendationResult[]

  @@index([recruiterId])
  @@index([companyId])
  @@index([categoryId])
  @@index([status])
  @@index([publishedAt])
  @@index([slug])
  @@index([deletedAt])
}

model Company {
  id        String   @id @default(uuid())
  name      String
  slug      String?  @unique
  logoUrl   String?
  iconKey   String?
  isTrusted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs Job[]

  @@index([isTrusted])
}

model JobCategory {
  id        String   @id @default(uuid())
  slug      String   @unique
  name      String
  iconKey   String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs Job[]

  @@index([sortOrder])
}

model SavedJob {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, jobId])
  @@index([userId])
  @@index([jobId])
}

model HomepageContent {
  id                     String   @id @default(uuid())
  slug                   String   @unique @default("home-main")
  heroHeadline           String
  heroSubheadline        String
  heroBackgroundImageUrl String
  popularKeywords        Json
  footerQuickLinks       Json
  footerSupportLinks     Json
  footerSocialLinks      Json
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model MarketStatDaily {
  id              String   @id @default(uuid())
  statDate        DateTime @db.Date @unique
  newJobs24h      Int      @default(0)
  activeJobs      Int      @default(0)
  hiringCompanies Int      @default(0)
  createdAt       DateTime @default(now())

  @@index([statDate(sort: Desc)])
}

model IndustryDemandDaily {
  id            String   @id @default(uuid())
  statDate      DateTime @db.Date
  industryKey   String
  industryLabel String
  demandValue   Int      @default(0)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())

  @@unique([statDate, industryKey])
  @@index([statDate(sort: Desc)])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String?  @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
}

model Application {
  id          String            @id @default(uuid())
  jobId       String
  job         Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidateId String
  candidate   Candidate         @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  cvId        String
  cv          CV                @relation(fields: [cvId], references: [id], onDelete: Restrict)
  matchScore  Float             @default(0)
  matchingSnapshot Json?
  status      ApplicationStatus @default(APPLIED)
  notes       String?           @db.Text
  appliedAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([jobId, candidateId])
  @@index([jobId])
  @@index([candidateId])
  @@index([cvId])
  @@index([matchScore])
  @@index([status])
}

enum RecommendationScanStatus {
  PROCESSING
  COMPLETED
  FAILED
}

model RecommendationScan {
  id            String                    @id @default(uuid())
  candidateId   String
  candidate     Candidate                 @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  cvId          String
  status        RecommendationScanStatus  @default(PROCESSING)
  totalJobs     Int                       @default(0)
  preFiltered   Int                       @default(0)
  aiEvaluated   Int                       @default(0)
  processingMs  Int?
  errorMessage  String?
  createdAt     DateTime                  @default(now())
  completedAt   DateTime?

  results       RecommendationResult[]

  @@index([candidateId, createdAt(sort: Desc)])
  @@index([status])
}

model RecommendationResult {
  id               String              @id @default(uuid())
  scanId           String
  scan             RecommendationScan  @relation(fields: [scanId], references: [id], onDelete: Cascade)
  jobId            String
  job              Job                 @relation(fields: [jobId], references: [id], onDelete: Cascade)
  rank             Int
  matchScore       Float
  matchTier        String
  matchingVersion  String
  matchingSnapshot Json?
  strengths        Json                @default("[]")
  gaps             Json                @default("[]")
  confidenceScore  Float               @default(0)
  createdAt        DateTime            @default(now())

  @@index([scanId, rank])
  @@index([jobId])
}

model Skill {
  id        String   @id @default(uuid())
  name      String   @unique
  category  String
  createdAt DateTime @default(now())

  @@index([name])
  @@index([category])
}
