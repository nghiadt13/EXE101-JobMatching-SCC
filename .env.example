# =========================
# API (apps/api)
# =========================
NODE_ENV=development
PORT=3001
WEB_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/job_matching

JWT_SECRET=change-me
JWT_EXPIRES_IN=1h

# AI normalization
LLM_PROVIDER=gemini
LLM_FALLBACK_PROVIDER=deepseek
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.1-flash-lite-preview
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
KIMI_API_KEY=your-kimi-api-key
KIMI_MODEL=kimi-k2.5
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
AI_NORMALIZATION_TIMEOUT_MS=20000

# Feature flags / tuning
API_JOBS_FILTERS_V1_ENABLED=true
API_JOBS_FACETS_V1_ENABLED=true
API_HOME_CACHE_TTL_MS=120000

# File storage (optional)
CV_UPLOAD_DIR=apps/api/uploads/cvs
JOB_UPLOAD_DIR=apps/api/uploads/jobs

# =========================
# WEB (apps/web)
# =========================
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_WEB_TRACKING_V1_ENABLED=false

AUTH_SECRET=change-me
NEXTAUTH_SECRET=change-me

# Social OAuth providers (NextAuth v5)
# Google: https://console.cloud.google.com/apis/credentials
#   Create OAuth client (Web application). Authorized redirect URI:
#   http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=your-google-oauth-client-id
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret

# Facebook: https://developers.facebook.com/apps/
#   Add Facebook Login product. Valid OAuth Redirect URI:
#   http://localhost:3000/api/auth/callback/facebook
AUTH_FACEBOOK_ID=your-facebook-app-id
AUTH_FACEBOOK_SECRET=your-facebook-app-secret

# Web feature flags
WEB_JOBS_FILTERS_V1_ENABLED=true
WEB_JOBS_LEGACY_REDIRECT_PERMANENT=false
